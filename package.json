{
  "name": "ged-backend",
  "version": "1.0.0",
  "description": "Gestion Électronique de Documents - Backend API",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/app.ts",
    "db:migrate": "ts-node src/utils/migration.ts",
    "db:migrate:create": "ts-node src/utils/migration.ts createTables",
    "db:migrate:reset": "ts-node src/utils/migration.ts resetDatabase",
    "db:seed": "ts-node src/utils/seeder.ts",
    "db:seed:truncate": "ts-node src/utils/seeder.ts truncate",
    "db:status": "ts-node -e \"import('./src/utils/migration.ts').then(m => m.default.status())\"",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.18.0",
    "nodemon": "^3.1.14",
    "sequelize": "^6.37.7",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
